RUDDER_JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
RUDDER_ENCRYPT_KEY=change-this-to-a-long-random-key-at-least-32-chars
RUDDER_RPC_AUTH_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# Database
RUDDER_DB_URL=jdbc:mysql://127.0.0.1:3306/rudder?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&allowMultiQueries=true
RUDDER_DB_USERNAME=rudder
RUDDER_DB_PASSWORD=rudder123

# redis
RUDDER_REDIS_HOST=127.0.0.1
RUDDER_REDIS_PORT=6379
RUDDER_REDIS_PASSWORD=123456
RUDDER_REDIS_DB=0
RUDDER_REDIS_SSL_ENABLED=false

# Ports (optional, uncomment to override defaults)
# RUDDER_API_HTTP_PORT=5680
# RUDDER_EXECUTION_HTTP_PORT=5681
# RUDDER_API_RPC_PORT=5690         # API 进程 Netty RPC 监听端口
# RUDDER_EXECUTION_RPC_PORT=5691   # Execution 进程 Netty RPC 监听端口

# 所有 SPI 配置（AI / 审批 / 元数据 / 文件 / 通知 / 版本存储）均在管理后台 UI 配置，
# 由 t_r_*_config 表驱动。历史 env 变量 RUDDER_AI_* / RUDDER_VERSION_STORE / RUDDER_GIT_* 已废弃。
