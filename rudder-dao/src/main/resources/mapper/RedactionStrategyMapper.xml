<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.zzih.rudder.dao.mapper.RedactionStrategyMapper">

    <select id="queryAllEnabled" resultType="io.github.zzih.rudder.dao.entity.RedactionStrategyEntity">
        select *
        from t_r_redaction_strategy
        where enabled = 1
        order by id asc
    </select>

    <select id="queryByCode" resultType="io.github.zzih.rudder.dao.entity.RedactionStrategyEntity">
        select *
        from t_r_redaction_strategy
        where code = #{code}
        limit 1
    </select>

</mapper>
