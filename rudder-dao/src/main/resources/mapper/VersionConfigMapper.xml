<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.zzih.rudder.dao.mapper.VersionConfigMapper">

    <select id="queryActive" resultType="io.github.zzih.rudder.dao.entity.VersionConfig">
        select *
        from t_r_version_config
        where enabled = 1
        order by id desc
        limit 1
    </select>

</mapper>
