<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>bin</id>
    <formats>
        <format>tar.gz</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>${project.build.finalName}-bin</baseDirectory>

    <fileSets>
        <!-- Global bin scripts -->
        <fileSet>
            <directory>src/main/bin</directory>
            <outputDirectory>bin</outputDirectory>
            <includes>
                <include>rudder-daemon.sh</include>
                <include>env.sh</include>
                <include>start-server.sh</include>
            </includes>
            <fileMode>0755</fileMode>
        </fileSet>

        <!-- API Server bin -->
        <fileSet>
            <directory>src/main/bin/api-server</directory>
            <outputDirectory>api-server/bin</outputDirectory>
            <useDefaultExcludes>true</useDefaultExcludes>
            <fileMode>0755</fileMode>
        </fileSet>

        <!-- API Server conf (from module resources) -->
        <fileSet>
            <directory>${project.basedir}/../rudder-api/src/main/resources</directory>
            <outputDirectory>api-server/conf</outputDirectory>
            <includes>
                <include>application.yml</include>
                <include>application-*.yml</include>
            </includes>
        </fileSet>

        <!-- API Server self jar -->
        <fileSet>
            <directory>${project.basedir}/../rudder-api/target</directory>
            <outputDirectory>api-server/libs</outputDirectory>
            <includes><include>rudder-api-${project.version}.jar</include></includes>
        </fileSet>

        <!-- API Server libs: rudder-api 模块自己收集到 target/libs,避免和 execution 依赖混装 -->
        <fileSet>
            <directory>${project.basedir}/../rudder-api/target/libs</directory>
            <outputDirectory>api-server/libs</outputDirectory>
            <includes><include>*.jar</include></includes>
        </fileSet>

        <!-- Execution Server bin -->
        <fileSet>
            <directory>src/main/bin/execution-server</directory>
            <outputDirectory>execution-server/bin</outputDirectory>
            <useDefaultExcludes>true</useDefaultExcludes>
            <fileMode>0755</fileMode>
        </fileSet>

        <!-- Execution Server conf (from module resources) -->
        <fileSet>
            <directory>${project.basedir}/../rudder-execution/src/main/resources</directory>
            <outputDirectory>execution-server/conf</outputDirectory>
            <includes>
                <include>application.yml</include>
                <include>application-*.yml</include>
            </includes>
        </fileSet>

        <!-- Execution Server self jar -->
        <fileSet>
            <directory>${project.basedir}/../rudder-execution/target</directory>
            <outputDirectory>execution-server/libs</outputDirectory>
            <includes><include>rudder-execution-${project.version}.jar</include></includes>
        </fileSet>

        <!-- Execution Server libs: rudder-execution 模块自己收集到 target/libs -->
        <fileSet>
            <directory>${project.basedir}/../rudder-execution/target/libs</directory>
            <outputDirectory>execution-server/libs</outputDirectory>
            <includes><include>*.jar</include></includes>
        </fileSet>

        <!-- Frontend UI dist -->
        <fileSet>
            <directory>${project.basedir}/../rudder-ui/dist</directory>
            <outputDirectory>ui</outputDirectory>
            <useDefaultExcludes>true</useDefaultExcludes>
            <excludes>
                <exclude>**/._*</exclude>
                <exclude>**/.DS_Store</exclude>
            </excludes>
        </fileSet>

        <!-- SQL scripts -->
        <fileSet>
            <directory>${project.basedir}/../rudder-dao/src/main/resources/sql</directory>
            <outputDirectory>sql</outputDirectory>
            <includes>
                <include>*.sql</include>
            </includes>
        </fileSet>
    </fileSets>
</assembly>
